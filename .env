DORKCOIN_RPC_USER=dorkcoinrpc
DORKCOIN_RPC_PASSWORD=replace_me_with_a_real_password

DORKCOIN_P2P_PORT=25516
DORKCOIN_RPC_PORT=25515

# Docker bridge-friendly default; tighten this if you know your subnet
DORKCOIN_RPC_ALLOW_IP=0.0.0.0/0
DORKCOIN_RPC_BIND=0.0.0.0

DORKCOIN_TXINDEX=1
DORKCOIN_PRUNE=0
DORKCOIN_MAXCONNECTIONS=64
DORKCOIN_BOOTSTRAP_NODES=170.75.161.131:25516
DORKCOIN_EXTRA_ARGS=